# OpenEMR base URL (no trailing slash). Production deploys override at build time.
# Dev:  https://localhost:9300   (HTTPS — required for OAuth2 flow to stay on one origin;
#                                 visit once in Chrome and accept the self-signed cert)
# Prod: https://oe.108-61-145-220.nip.io
VITE_OPENEMR_BASE_URL=https://localhost:9300

# OAuth2 client ID — obtained via PD-16 dynamic client registration on the LOCAL OpenEMR.
# OpenEMR rejects token_endpoint_auth_method=none, so we registered as client_secret_post.
# OpenEMR returned an EMPTY client_secret (effectively public) — set CLIENT_SECRET below
# to '' (empty) to match. PKCE remains the security mechanism.
VITE_OAUTH_CLIENT_ID=replace-with-client-id-from-PD-16
VITE_OAUTH_CLIENT_SECRET=

# Redirect URI — must exactly match a redirect_uris entry registered with OpenEMR.
# Dev:  http://localhost:5174/callback
# Prod: https://<vps>/dashboard/callback (re-register before Saturday deploy)
VITE_OAUTH_REDIRECT_URI=http://localhost:5174/callback

# OAuth2 scopes — explicit per-resource (OpenEMR rejects the wildcard patient/*.read at registration).
# offline_access is dropped (would force confidential-with-real-secret per OpenEMR's UI hint).
# Tradeoff: no refresh token; access token ~1h; user re-auths after expiry.
VITE_OAUTH_SCOPES=openid fhirUser launch/patient patient/Patient.read patient/AllergyIntolerance.read patient/Condition.read patient/MedicationRequest.read patient/CareTeam.read patient/Observation.read patient/Immunization.read patient/Appointment.read
