{
  "name": "@agentforge/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "dotenv -e ../../docker/agentforge/secrets.dev.env -- node scripts/pg-migrate.mjs",
    "rag-index": "dotenv -e ../../docker/agentforge/secrets.dev.env -- node scripts/build-rag-index.mjs",
    "dev": "dotenv -e ../../docker/agentforge/secrets.dev.env -- tsx watch src/index.ts",
    "dev:host": "dotenv -e ../../docker/agentforge/secrets.dev.env -v POSTGRES_URL=postgresql://agentforge:agentforge@127.0.0.1:15432/agentforge -- tsx watch src/index.ts",
    "test": "vitest run",
    "eval": "tsx eval/runner.ts",
    "eval:judge": "dotenv -e ../../docker/agentforge/secrets.dev.env -v EVAL_RUN_JUDGE=1 -- tsx eval/runner.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/azure": "^3.0.59",
    "@anthropic-ai/sdk": "^0.93.0",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.3.0",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.170",
    "cohere-ai": "^8.0.0",
    "hono": "^4.6.0",
    "langfuse": "^3.38.20",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
