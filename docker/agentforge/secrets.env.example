# Template for `docker/agentforge/secrets.dev.env` and `docker/agentforge/secrets.prod.env`.
# Both files are gitignored (*.env). Copy this template, then edit:
#   - AGENTFORGE_PUBLIC_HOSTNAME → bare hostname only (prod Caddy + ACME); no scheme
#   - CUI_ALLOWED_ORIGINS        → OpenEMR site Origin(s), comma-separated
#   - OPENEMR_MODULE_SHARED_SECRET / SESSION_TOKEN_SECRET → `openssl rand -hex 32`,
#     unique per environment, MIRRORED across `agentforge-api` and the OpenEMR PHP runtime.
# See `agentforge/api/src/env.ts` for the canonical key list.

# Browser-facing / TLS (prod: Caddy + Let's Encrypt HTTP-01 on :80 / :443)
AGENTFORGE_PUBLIC_HOSTNAME=api.example.com
AGENTFORGE_API_PUBLIC_URL=https://api.example.com
CUI_ALLOWED_ORIGINS=https://oe.example.com

# LLM / STT
LLM_PROVIDER=anthropic
LLM_API_KEY=replace-me
STT_PROVIDER=deepgram
STT_API_KEY=replace-me

# OpenEMR S2S
OPENEMR_MODULE_BASE_URL=https://oe.example.com/interface/modules/custom_modules/oe-module-agentforge/public
OPENEMR_MODULE_SHARED_SECRET=replace-me-use-openssl-rand-hex-32-or-longer

# Storage / observability
POSTGRES_URL=postgresql://agentforge:agentforge@postgres:5432/agentforge
LANGFUSE_BASE_URL=https://langfuse.example.com
LANGFUSE_PUBLIC_KEY=replace-me
LANGFUSE_SECRET_KEY=replace-me

# Session token (mirror in PHP runtime)
SESSION_TOKEN_SECRET=replace-me-use-openssl-rand-hex-32-or-longer

LOG_LEVEL=info
