# Template for `docker/agentforge/secrets.dev.env` and `docker/agentforge/secrets.prod.env`.
# Both files are gitignored (*.env). Copy this template, then edit:
#   - AGENTFORGE_PUBLIC_HOSTNAME → bare hostname only (prod Caddy + ACME); no scheme
#   - CUI_ALLOWED_ORIGINS        → OpenEMR site Origin(s), comma-separated
#   - OPENEMR_MODULE_SHARED_SECRET / SESSION_TOKEN_SECRET → `openssl rand -hex 32`,
#     unique per environment, MIRRORED across `agentforge-api` and the OpenEMR PHP runtime.
# See `agentforge/api/src/env.ts` for the canonical key list.

# Browser-facing / TLS (prod: Caddy + Let's Encrypt HTTP-01 on :80 / :443)
AGENTFORGE_PUBLIC_HOSTNAME=api.example.com
AGENTFORGE_API_PUBLIC_URL=https://api.example.com
CUI_ALLOWED_ORIGINS=https://oe.example.com

# LLM / STT
# anthropic | openai_azure  (PRD §5.7 / G6-15 — env-only provider swap).
# When LLM_PROVIDER=openai_azure, populate the OPENAI_AZURE_* keys below;
# `LLM_API_KEY` then carries the Azure subscription key.
LLM_PROVIDER=anthropic
LLM_API_KEY=replace-me
# Azure OpenAI configuration (only consulted when LLM_PROVIDER=openai_azure).
# Either OPENAI_AZURE_RESOURCE_NAME (Azure-managed endpoint) or
# OPENAI_AZURE_BASE_URL (proxy / private endpoint) must be set, plus the
# deployment id of the chat model. API version defaults to `preview` if unset.
#OPENAI_AZURE_RESOURCE_NAME=my-azure-openai-resource
#OPENAI_AZURE_BASE_URL=https://my-proxy.example.com/azure-oai
#OPENAI_AZURE_DEPLOYMENT_ID=gpt-4o-mini-prod
#OPENAI_AZURE_API_VERSION=2024-10-21
# deepgram | assemblyai | mock (mock = dev/tests; no external STT — still needs a placeholder STT_API_KEY for env schema)
STT_PROVIDER=deepgram
STT_API_KEY=replace-me

# OpenEMR S2S
OPENEMR_MODULE_BASE_URL=https://oe.example.com/interface/modules/custom_modules/oe-module-agentforge/public
OPENEMR_MODULE_SHARED_SECRET=replace-me-use-openssl-rand-hex-32-or-longer

# Storage / observability
# Containers (API, Langfuse) — hostname `postgres` resolves only on the Compose network.
POSTGRES_URL=postgresql://agentforge:agentforge@postgres:5432/agentforge

# OPTIONAL — migrations / psql from the Mac host when Postgres publishes 127.0.0.1:15432 (see docker-compose.override).
# Overrides nothing inside containers unless you duplicate this key there (don't). Prefer inline for one-shot:
#   POSTGRES_URL_MIGRATE='postgresql://agentforge:agentforge@127.0.0.1:15432/agentforge' npm run db:migrate
#POSTGRES_URL_MIGRATE=postgresql://agentforge:agentforge@127.0.0.1:15432/agentforge
LANGFUSE_BASE_URL=https://langfuse.example.com
LANGFUSE_PUBLIC_KEY=replace-me
LANGFUSE_SECRET_KEY=replace-me

# Session token (mirror in PHP runtime)
SESSION_TOKEN_SECRET=replace-me-use-openssl-rand-hex-32-or-longer

LOG_LEVEL=info
