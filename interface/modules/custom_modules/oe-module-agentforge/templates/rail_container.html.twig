{# Embedded right-column CUI panel (PRD §4.2; sibling of #framesDisplay inside #mainFrames_div).
   Stays mounted across tab switches and toggle (G2-13); pid polling + iframe blank/reload (G3-12);
   §6.7 NAV_REQUEST routes encounter / chart_section back into the host tab system. #}
<div id="agentforge-rail"
     class="agentforge-rail"
     data-rail-width="{{ rail_width }}"
     {% if rail_patient_uuid != '' %}data-shell-patient-uuid="{{ rail_patient_uuid }}"{% endif %}
     data-web-root="{{ web_root_js }}"
     style="--agentforge-rail-width: {{ rail_width }}px;">
    <iframe id="agentforge-cui-frame"
            class="agentforge-rail__iframe"
            title="{{ 'Clinical Copilot panel'|xl }}"
            src="about:blank"
            data-panel-src="{{ panel_src|e('html_attr') }}"
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups allow-popups-to-escape-sandbox"></iframe>
</div>
<div id="agentforge-rail-splitter"
     class="agentforge-rail-splitter"
     role="separator"
     aria-orientation="vertical"
     aria-label="{{ 'Resize Clinical Copilot panel'|xla }}"
     tabindex="0"></div>
<style>
    /* #mainFrames_div is .d-flex.flex-row; we live as flex children alongside #framesDisplay. */
    #mainFrames_div #framesDisplay {
        flex: 1 1 auto;
        min-width: 0;
    }

    .agentforge-rail {
        flex: 0 0 var(--agentforge-rail-width, 420px);
        min-width: 320px;
        max-width: 600px;
        background: #fff;
        border-inline-start: 1px solid #d0d0d8;
        box-shadow: -1px 0 6px rgba(0, 0, 0, 0.06);
        display: flex;
        flex-direction: column;
        min-height: 0;
        align-self: stretch;
    }

    .agentforge-rail--collapsed,
    .agentforge-rail-splitter--hidden {
        display: none !important;
    }

    /* G2-Final-31 — top-level document preview overlay. Rendered by the
     * host (not inside the CUI iframe) so it sits OVER both the OpenEMR
     * app and the CUI rail without disturbing either layout. The PDF
     * itself renders inside a nested iframe with our pdfjs-driven
     * document-viewer.html.
     *
     * Sizing uses explicit viewport units (`100vw` / `100vh`) instead
     * of the `inset: 0` shorthand because OpenEMR's main.php body
     * stack contains transforms / containment that intermittently
     * collapsed the overlay to its content size. Viewport units are
     * resolved against the layout viewport regardless of containing
     * block, so this is bulletproof. */
    .agentforge-document-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.85);
        z-index: 99999;
    }

    /* Close × — dark-mode variant tuned to the modal's dim backdrop.
     * Mirrors the *shape* and corner-radius of the CUI rail's icon
     * buttons (`.agentforge-cui__refresh`) so the affordance still
     * reads as a button, but inverts the surface treatment so it
     * blends with the lightbox aesthetic instead of fighting it.
     * Slightly larger (2.75rem vs 2.25rem) and a beefier × glyph
     * (28px) for visibility against the busy PDF preview behind it.
     * Soft frosted-glass feel via low-alpha white surface + border. */
    .agentforge-document-overlay__close {
        box-sizing: border-box;
        position: absolute;
        top: 32px;
        left: 32px;
        z-index: 1;
        cursor: pointer;
        width: 2.75rem;
        height: 2.75rem;
        padding: 0;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 6px;
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.92);
        line-height: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
        transition: background-color 120ms ease, border-color 120ms ease, transform 120ms ease;
    }

    /* Sized via CSS so the icon scales with the button if the button
     * size ever changes. 20px gives the glyph generous breathing room
     * inside the 44px square — about 45% of the button width, which is
     * the proportion most close-icon designs use. */
    .agentforge-document-overlay__close-icon {
        width: 20px;
        height: 20px;
        display: block;
    }

    .agentforge-document-overlay__close:hover {
        background: rgba(255, 255, 255, 0.16);
        border-color: rgba(255, 255, 255, 0.32);
    }

    .agentforge-document-overlay__close:active {
        transform: scale(0.96);
    }

    .agentforge-document-overlay__close:focus-visible {
        outline: none;
        box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.35);
    }

    /* Iframe sized via explicit width/height with `calc()` rather than
     * `inset: 24px` — replaced elements (iframes) don't always honor
     * the inset shorthand when the parent's containing-block geometry
     * is contested. `display: block` removes the inline-baseline gap
     * an iframe would otherwise leave. */
    .agentforge-document-overlay__frame {
        position: absolute;
        top: 24px;
        left: 24px;
        width: calc(100% - 48px);
        height: calc(100% - 48px);
        display: block;
        border: 0;
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .agentforge-rail__iframe {
        flex: 1 1 auto;
        border: 0;
        width: 100%;
        min-height: 0;
        display: block;
    }

    .agentforge-rail-splitter {
        flex: 0 0 4px;
        cursor: col-resize;
        background: transparent;
        position: relative;
        user-select: none;
        align-self: stretch;
    }

    .agentforge-rail-splitter:hover,
    .agentforge-rail-splitter--dragging {
        background: #c0c4cc;
    }

    .agentforge-rail-splitter:focus-visible {
        outline: 2px solid #0645ad;
        outline-offset: -2px;
    }

    /* While dragging, suppress iframe pointer interception so the splitter follows the cursor. */
    body.agentforge-rail-dragging iframe {
        pointer-events: none;
    }

    body.agentforge-rail-dragging {
        cursor: col-resize;
        user-select: none;
    }
</style>
<script>
    (function () {
        var STORAGE_KEY_WIDTH = 'agentforge.rail.width';
        var STORAGE_KEY_COLLAPSED = 'agentforge.rail.collapsed';
        var MIN_WIDTH = 320;
        var MAX_WIDTH = 600;
        var MIN_FRAMES_WIDTH = 480;

        var rail = document.getElementById('agentforge-rail');
        var splitter = document.getElementById('agentforge-rail-splitter');
        var toggle = document.getElementById('agentforge-rail-toggle');
        var frame = document.getElementById('agentforge-cui-frame');
        if (!rail || !splitter || !toggle) {
            return;
        }

        // Probe the active OpenEMR theme's `.btn-outline-secondary` color and
        // expose it as `--toggle-active-color` on the toggle button. The
        // [aria-expanded="true"] CSS in header_icon.html.twig uses that var
        // for fill/border so the panel-open look stays in sync with the
        // closed-hover look across all themes (default #1f2937, cobalt
        // #467ac2, solar #002b36, etc.) without hardcoding any one swatch.
        try {
            var probe = document.createElement('span');
            probe.className = 'btn btn-outline-secondary';
            probe.style.cssText = 'position:absolute;visibility:hidden;pointer-events:none;';
            document.body.appendChild(probe);
            var themedColor = window.getComputedStyle(probe).color;
            document.body.removeChild(probe);
            if (themedColor && themedColor !== '') {
                toggle.style.setProperty('--toggle-active-color', themedColor);
            }
        } catch (ignored) {
            // Fall back to the inline-style default in header_icon.html.twig.
        }

        var defaultWidth = parseInt(rail.getAttribute('data-rail-width') || '420', 10) || 420;
        var panelSrc = frame ? frame.getAttribute('data-panel-src') || '' : '';
        var panelLoaded = false;
        var webRoot = rail.getAttribute('data-web-root') || '';

        function safeSessionGet(key) {
            try {
                return window.sessionStorage.getItem(key);
            } catch (ignored) {
                return null;
            }
        }

        function safeSessionSet(key, val) {
            try {
                window.sessionStorage.setItem(key, val);
            } catch (ignored) {
                /* ignore quota / private mode errors — preference is best-effort */
            }
        }

        function clampWidth(px) {
            if (!isFinite(px)) {
                return defaultWidth;
            }
            if (px < MIN_WIDTH) {
                return MIN_WIDTH;
            }
            if (px > MAX_WIDTH) {
                return MAX_WIDTH;
            }
            return px;
        }

        function applyWidth(px) {
            var w = clampWidth(px);
            rail.style.setProperty('--agentforge-rail-width', w + 'px');
            return w;
        }

        // Fresh sessions (no stored width) default to the maximum width so
        // the copilot opens with the most vertical-room-for-chat layout.
        // Returning sessions keep whatever width they last dragged to.
        var storedWidth = parseInt(safeSessionGet(STORAGE_KEY_WIDTH) || '', 10);
        applyWidth(isFinite(storedWidth) && storedWidth > 0 ? storedWidth : MAX_WIDTH);

        // One-shot per session: collapse the OpenEMR top patient panel
        // (`#attendantData`, toggled by `#patient_caret`) so the copilot
        // takes over the encounter-strip's role and frees vertical space.
        // Sticky for the session — if the user re-expands, we don't fight
        // them; new tab/session starts collapsed again.
        try {
            var ATTENDANT_INIT_KEY = 'agentforge.attendant.initialized';
            if (window.sessionStorage && !window.sessionStorage.getItem(ATTENDANT_INIT_KEY)) {
                var attendantData = document.getElementById('attendantData');
                var patientCaret = document.getElementById('patient_caret');
                if (attendantData && patientCaret) {
                    attendantData.style.display = 'none';
                    patientCaret.classList.remove('fa-caret-up');
                    patientCaret.classList.add('fa-caret-down');
                }
                window.sessionStorage.setItem(ATTENDANT_INIT_KEY, '1');
            }
        } catch (ignored) {
            /* storage blocked / DOM not yet rendered — fall back to default expanded */
        }

        /** Prefer OpenEMR tab APIs / RTop; never assign window.top.location (drops rail + tabs chrome). */
        function baseWebRoot() {
            var topWin = window.top;
            try {
                if (typeof topWin.webroot_url === 'string' && topWin.webroot_url !== '') {
                    return topWin.webroot_url;
                }
            } catch (ignored) {
            }
            return webRoot;
        }

        function navigateEncounterInChrome(encId) {
            var topWin = window.top;
            var root = baseWebRoot();
            var url =
                root +
                '/interface/patient_file/encounter/encounter_top.php?set_encounter=' +
                encodeURIComponent(String(encId));
            if (typeof topWin.goToEncounter === 'function') {
                topWin.goToEncounter(encId);
                return;
            }
            if (typeof topWin.navigateTab === 'function') {
                topWin.navigateTab(url, 'enc', function () {
                    if (typeof topWin.activateTabByName === 'function') {
                        topWin.activateTabByName('enc', true);
                    }
                });
                return;
            }
            try {
                if (topWin.RTop && topWin.RTop.location) {
                    topWin.RTop.location = url;
                }
            } catch (ignored) {
            }
        }

        function navigateVisitHistoryInChrome() {
            var topWin = window.top;
            var root = baseWebRoot();
            var url = root + '/interface/patient_file/history/encounters.php';
            if (typeof topWin.encounterList === 'function') {
                topWin.encounterList();
                return;
            }
            if (typeof topWin.navigateTab === 'function') {
                topWin.navigateTab(url, 'enc', function () {
                    if (typeof topWin.activateTabByName === 'function') {
                        topWin.activateTabByName('enc', true);
                    }
                });
                return;
            }
            try {
                if (topWin.RTop && topWin.RTop.location) {
                    topWin.RTop.location = url;
                }
            } catch (ignored) {
            }
        }

        function navigateDemographicsInChrome() {
            var topWin = window.top;
            var root = baseWebRoot();
            var url = root + '/interface/patient_file/summary/demographics.php';
            if (typeof topWin.loadCurrentPatient === 'function') {
                topWin.loadCurrentPatient();
                return;
            }
            if (typeof topWin.navigateTab === 'function') {
                topWin.navigateTab(url, 'pat', function () {
                    if (typeof topWin.activateTabByName === 'function') {
                        topWin.activateTabByName('pat', true);
                    }
                });
                return;
            }
            try {
                if (topWin.RTop && topWin.RTop.location) {
                    topWin.RTop.location = url;
                }
            } catch (ignored) {
            }
        }

        /** URLs align with Dashboard card links in demographics.php and patient menu (standard.json). */
        function urlForChartSection(section, pidStr) {
            var root = baseWebRoot();
            var demos = root + '/interface/patient_file/summary/demographics.php';
            if (!section || typeof section !== 'string') {
                return demos;
            }
            switch (section) {
                case 'demographics':
                    return demos;
                case 'allergies':
                    return root + '/interface/patient_file/summary/stats_full.php?active=all&category=allergy';
                case 'medical_problem':
                    return root + '/interface/patient_file/summary/stats_full.php?active=all&category=medical_problem';
                case 'medications':
                    return root + '/interface/patient_file/summary/stats_full.php?active=all&category=medication';
                case 'vitals':
                    return root + '/interface/patient_file/encounter/trend_form.php?formname=vitals&context=dashboard';
                case 'labs':
                    return root + '/interface/patient_file/summary/labdata.php';
                case 'social_history':
                    return root + '/interface/patient_file/history/history.php';
                case 'documents':
                    if (pidStr && pidStr !== '') {
                        return root + '/controller.php?document&list&patient_id=' + encodeURIComponent(pidStr);
                    }
                    return demos;
                default:
                    return demos;
            }
        }

        function navigatePatTabUrl(url) {
            var topWin = window.top;
            if (typeof topWin.navigateTab === 'function') {
                topWin.navigateTab(url, 'pat', function () {
                    if (typeof topWin.activateTabByName === 'function') {
                        topWin.activateTabByName('pat', true);
                    }
                });
                return;
            }
            try {
                if (topWin.RTop && topWin.RTop.location) {
                    topWin.RTop.location = url;
                }
            } catch (ignored) {
            }
        }

        function navigateChartSectionFromHint(params) {
            var p = params && typeof params === 'object' ? params : {};
            var section = typeof p.section === 'string' ? p.section : '';
            var pidStr = readPidProbe();
            if (!section || section === 'demographics') {
                navigateDemographicsInChrome();
                return;
            }
            navigatePatTabUrl(urlForChartSection(section, pidStr));
        }

        function readPidProbe() {
            try {
                var appPatient =
                    window.top &&
                    window.top.app_view_model &&
                    window.top.app_view_model.application_data &&
                    window.top.app_view_model.application_data.patient &&
                    window.top.app_view_model.application_data.patient();
                if (appPatient && appPatient.pid) {
                    var appPid = appPatient.pid();
                    if (appPid !== null && appPid !== undefined && String(appPid) !== '') {
                        return String(appPid);
                    }
                }
            } catch (ignored) {
                // Fall back to DOM probes below; cross-frame errors should not break the rail.
            }

            var inp = document.querySelector('input[name="pid"]');
            return inp && inp.value ? String(inp.value) : '';
        }

        // Post-deploy P2 fix: also probe the active encounter id from the same
        // top-level OpenEMR view-model so the rail re-mints the launch code
        // (and therefore the JWT's encounter_id claim) when the operator saves
        // a new encounter mid-session. Before this, the JWT was frozen at the
        // value of $_SESSION['encounter'] at handshake and the agent kept
        // refusing dictation with "no recent encounter for today".
        function readEncounterProbe() {
            try {
                var appPatient =
                    window.top &&
                    window.top.app_view_model &&
                    window.top.app_view_model.application_data &&
                    window.top.app_view_model.application_data.patient &&
                    window.top.app_view_model.application_data.patient();
                if (appPatient && typeof appPatient.selectedEncounterID === 'function') {
                    var raw = appPatient.selectedEncounterID();
                    if (raw !== null && raw !== undefined && String(raw) !== '') {
                        return String(raw);
                    }
                }
            } catch (ignored) {
                // Cross-frame errors should not break the rail; missing encounter id is fine.
            }

            return '';
        }

        var prevPid = readPidProbe();
        var prevEncounter = readEncounterProbe();

        // Walks the iframe tree from window.top down, calling refreshVisitDisplay() on the first
        // frame that defines it (encounter_top.php). Mirrors how OpenEMR's own tabs_view_model.js
        // (line ~343) discovers the encounter frame by feature-detecting twAddFrameTab. Best
        // effort: cross-origin frames throw on access and are silently skipped.
        function triggerOpenEmrEncounterRefresh() {
            var done = false;
            function walk(win) {
                if (!win || done) return;
                try {
                    if (typeof win.refreshVisitDisplay === 'function') {
                        win.refreshVisitDisplay();
                        done = true;
                        return;
                    }
                    var nested = win.frames;
                    if (!nested) return;
                    for (var i = 0; i < nested.length; i++) {
                        walk(nested[i]);
                        if (done) return;
                    }
                } catch (ignored) {
                    // cross-origin / detached frame; skip
                }
            }
            walk(window.top);
        }

        function syncBoundEncounterInChrome(encId, encounterDate, encounterCategory) {
            var topWin = window.top;
            try {
                var appPatient =
                    topWin &&
                    topWin.app_view_model &&
                    topWin.app_view_model.application_data &&
                    topWin.app_view_model.application_data.patient &&
                    topWin.app_view_model.application_data.patient();
                if (!appPatient || typeof appPatient.selectedEncounterID !== 'function') {
                    return;
                }

                var encString = String(encId);
                if (typeof appPatient.encounterArray === 'function') {
                    var encounters = appPatient.encounterArray();
                    var found = false;
                    for (var i = 0; i < encounters.length; i++) {
                        var cur = encounters[i];
                        if (cur && cur.id && String(cur.id()) === encString) {
                            found = true;
                            break;
                        }
                    }
                    if (!found && encounterDate !== '' && typeof topWin.encounter_data === 'function') {
                        appPatient.encounterArray.push(new topWin.encounter_data(encString, encounterDate, encounterCategory));
                    }
                }

                appPatient.selectedEncounterID(encString);
                prevEncounter = encString;
            } catch (ignored) {
                // Host encounter sync is best-effort; the server session/token are already bound.
            }
        }

        function syncBoundEncounterFromFrame() {
            if (!frame) {
                return;
            }
            var doc = null;
            try {
                doc = frame.contentDocument;
            } catch (ignored) {
                return;
            }
            var root = doc ? doc.documentElement : null;
            if (!root) {
                return;
            }
            var rawEnc = root.getAttribute('data-bound-encounter-id') || '';
            var encId = parseInt(rawEnc, 10);
            if (!(encId > 0)) {
                return;
            }
            syncBoundEncounterInChrome(
                encId,
                root.getAttribute('data-bound-encounter-date') || '',
                root.getAttribute('data-bound-encounter-category') || ''
            );
        }

        // Brief auto-trigger lives inside the CUI now (App.tsx state machine).
        // The host previously fired a present-patient postMessage on iframe
        // load / pid-poll / setCollapsed (with a 200ms setTimeout race window)
        // and the CUI listened for it. That handshake had four failure modes:
        //   1. the message arrived before React mounted its listener,
        //   2. the message arrived before the CUI handshake reached `ready`,
        //   3. StrictMode double-fired the trigger,
        //   4. the rail re-mount after a chart change blanked the CUI before
        //      the message landed.
        // The CUI now self-triggers on (handshake.status === 'ready'
        // && patientUuid !== null) so the host only needs to manage the
        // iframe lifecycle: blank on chart change, mount on un-collapse.
        // See Documentation/AgentForge/process/journal/week-1/0501-T1500-brief-consistency-cache.md.

        // G2-Final-31 — host-side document preview overlay. Lives at the
        // top of the OpenEMR DOM so it covers both the main app and the
        // CUI rail. Uses the browser's native PDF viewer in a nested
        // iframe — no pdfjs in the host, and same-origin cookies flow
        // through the bytes endpoint so ChartContextGate authorizes
        // exactly as it does for any other module HTTP call.
        var documentOverlay = null;
        var documentOverlayKeyHandler = null;
        function openDocumentOverlay(bytesUrl, initialPage) {
            closeDocumentOverlay();

            var overlay = document.createElement('div');
            overlay.className = 'agentforge-document-overlay';
            overlay.setAttribute('role', 'dialog');
            overlay.setAttribute('aria-modal', 'true');
            overlay.setAttribute('aria-label', 'Document preview');

            var closeBtn = document.createElement('button');
            closeBtn.type = 'button';
            closeBtn.className = 'agentforge-document-overlay__close';
            closeBtn.setAttribute('aria-label', 'Close document preview');
            // Stroked SVG × instead of the unicode multiplication sign:
            // the unicode glyph has font-baseline quirks that nudge it
            // off optical center inside flex layouts, while a viewBox-
            // geometric × is perfectly centered. Same stroked-currentColor
            // pattern the CUI rail uses for its other inline icons.
            closeBtn.innerHTML =
                '<svg class="agentforge-document-overlay__close-icon" ' +
                'viewBox="0 0 24 24" fill="none" stroke="currentColor" ' +
                'stroke-width="2" stroke-linecap="round" stroke-linejoin="round" ' +
                'aria-hidden="true" focusable="false">' +
                '<path d="M6 6 18 18M18 6 6 18"></path>' +
                '</svg>';
            closeBtn.addEventListener('click', closeDocumentOverlay);

            var pdfFrame = document.createElement('iframe');
            pdfFrame.className = 'agentforge-document-overlay__frame';
            pdfFrame.title = 'Document preview';
            // Render through our pdfjs-driven viewer.html (stacked-canvas
            // scroll) instead of pointing the iframe at the raw bytes URL.
            // Chrome's embedded PDF plugin scrolls jankily inside nested
            // iframes; HTML-native scroll on stacked canvases is smooth
            // and consistent across browsers.
            var page = (typeof initialPage === 'number' && initialPage > 0) ? initialPage : 1;
            var viewerUrl =
                webRoot +
                '/interface/modules/custom_modules/oe-module-agentforge/public/cui/document-viewer.html' +
                '?file=' + encodeURIComponent(bytesUrl) +
                '&page=' + encodeURIComponent(String(page));
            pdfFrame.src = viewerUrl;

            // Order matters for tab focus: iframe first so the PDF
            // is the primary interactive element; close button second
            // so Esc / Tab cycle hits it after PDF interaction.
            overlay.appendChild(pdfFrame);
            overlay.appendChild(closeBtn);

            // Click on the dim backdrop (not the iframe) closes; clicks
            // inside the PDF frame are passed through to the viewer.
            overlay.addEventListener('click', function (ev) {
                if (ev.target === overlay) {
                    closeDocumentOverlay();
                }
            });

            documentOverlayKeyHandler = function (ev) {
                if (ev.key === 'Escape') {
                    closeDocumentOverlay();
                }
            };
            window.addEventListener('keydown', documentOverlayKeyHandler);

            document.body.appendChild(overlay);
            documentOverlay = overlay;

            // Move focus into the overlay so Esc + tab navigation work.
            try {
                closeBtn.focus({ preventScroll: true });
            } catch (ignored) {
                // older browsers without focus options — fall through silently
            }
        }

        function closeDocumentOverlay() {
            if (documentOverlayKeyHandler !== null) {
                window.removeEventListener('keydown', documentOverlayKeyHandler);
                documentOverlayKeyHandler = null;
            }
            if (documentOverlay !== null) {
                documentOverlay.remove();
                documentOverlay = null;
            }
        }

        function blankPanelIframe() {
            panelLoaded = false;
            if (frame) {
                frame.setAttribute('src', 'about:blank');
            }
        }

        setInterval(function () {
            var cur = readPidProbe();
            var curEnc = readEncounterProbe();
            // Pid change OR encounter change re-mints the launch code via the
            // panel reload — both are reasons the JWT's bound chart context is
            // now stale. Encounter change alone (P2 fix) is the common case
            // when the operator clicks "Save Encounter" mid-rail-session.
            if (cur !== prevPid || curEnc !== prevEncounter) {
                prevPid = cur;
                prevEncounter = curEnc;
                blankPanelIframe();
                if (!rail.classList.contains('agentforge-rail--collapsed')) {
                    ensurePanelLoaded();
                }
            }
        }, 1500);

        if (frame) {
            frame.addEventListener('load', syncBoundEncounterFromFrame);
        }

        window.addEventListener('message', function (ev) {
            if (!frame || ev.source !== frame.contentWindow) {
                return;
            }
            if (ev.origin !== window.location.origin) {
                return;
            }
            var data = ev.data;
            if (!data || typeof data !== 'object') {
                return;
            }

            // G2-Final-31 — open a top-level document preview overlay. The CUI iframe is
            // sandboxed and constrained to the rail's panel area, so the modal cannot escape
            // it. We render the overlay in the OpenEMR shell DOM instead — it sits over both
            // the app and the rail without expanding the iframe. The PDF renders inside a
            // nested iframe with the browser's native PDF viewer (no pdfjs in the host),
            // which also avoids the buffer-detach bug we hit when reusing cached Uint8Array
            // bytes through pdfjs across multiple opens.
            if (data.type === 'AGENTFORGE_OPEN_DOCUMENT_OVERLAY') {
                var bytesUrl = typeof data.bytes_url === 'string' ? data.bytes_url : '';
                if (bytesUrl === '') {
                    return;
                }
                var initialPage = typeof data.initial_page === 'number' ? data.initial_page : 1;
                openDocumentOverlay(bytesUrl, initialPage);
                return;
            }

            // After a confirmed write (clinical note / vitals / chief complaint / etc.) the CUI
            // posts WRITE_CONFIRMED so the open encounter view can re-render without the operator
            // hitting the encounter Refresh button. We bridge into OpenEMR's existing
            // refreshVisitDisplay() defined on encounter_top.php (its loop calls each tab frame's
            // own refreshVisitDisplay, which in turn hard-reloads forms.php).
            //
            // Frame hierarchy: this script runs in main.php (rail container is body-injected, not
            // iframed), and encounter_top.php is loaded as a child frame of main.php. So we walk
            // window.top.frames to find the frame that has refreshVisitDisplay defined — same
            // pattern OpenEMR's tabs_view_model.js uses to find encounter_top by looking for
            // twAddFrameTab. Calling top.refreshVisitDisplay() directly would no-op because
            // main.php doesn't define that function.
            //
            // Patient-binding guard: ignore stale messages from a previous chart by comparing the
            // expected_patient_uuid (sent by CUI) against the iframe's data-patient-uuid attribute
            // (set on iframe-root by the CUI when bound). Mismatch = silently drop.
            if (data.type === 'WRITE_CONFIRMED') {
                var docW = null;
                try {
                    docW = frame.contentDocument;
                } catch (ignored) {
                    return;
                }
                var iframeRootW = docW ? docW.documentElement : null;
                var boundUuidW = iframeRootW ? (iframeRootW.getAttribute('data-patient-uuid') || '') : '';
                var expectedW = typeof data.expected_patient_uuid === 'string' ? data.expected_patient_uuid : '';
                if (expectedW !== '' && boundUuidW !== '' && expectedW !== boundUuidW) {
                    return;
                }
                triggerOpenEmrEncounterRefresh();

                // P5 fix (Bug A): patient-level writes update lists / demographics
                // panes outside encounter forms. `triggerOpenEmrEncounterRefresh()`
                // only reloads `forms.php` (the encounter forms panel) — for
                // allergies / medications / family history / demographics /
                // intake-confirm, the new data lives on the demographics tab and
                // the patient sidebar, which `forms.php` does not include. Also
                // call `navigateDemographicsInChrome()` (which calls OpenEMR's
                // `loadCurrentPatient()` — the same global the top-bar
                // patient-name link is bound to) so those surfaces refresh
                // without the operator manually clicking the patient name.
                // Encounter-level write_targets (chief_complaint, vitals,
                // clinical_note, tobacco) are intentionally excluded — their
                // surfaces are already handled by the encounter refresh above.
                var patientLevelWriteTargets = [
                    'intake_proposal',
                    'allergy',
                    'allergy_delete',
                    'medication_add',
                    'medication_discontinue',
                    'family_history_add',
                    'demographics_update'
                ];
                var writeTarget = typeof data.write_target === 'string' ? data.write_target : '';
                if (writeTarget !== '' && patientLevelWriteTargets.indexOf(writeTarget) !== -1) {
                    navigateDemographicsInChrome();
                }
                return;
            }

            if (data.type !== 'NAV_REQUEST') {
                return;
            }
            var doc = null;
            try {
                doc = frame.contentDocument;
            } catch (ignored) {
                return;
            }
            var iframeRoot = doc ? doc.documentElement : null;
            var boundUuid = iframeRoot ? (iframeRoot.getAttribute('data-patient-uuid') || '') : '';
            var expected = typeof data.expected_patient_uuid === 'string' ? data.expected_patient_uuid : '';
            if (expected !== '' && boundUuid !== '' && expected !== boundUuid && frame.contentWindow) {
                frame.contentWindow.postMessage({ type: 'NAV_REFUSED', reason: 'chart_mismatch' }, window.location.origin);
                return;
            }
            var hint = data.hint;
            if (!hint || typeof hint.kind !== 'string') {
                return;
            }
            if (typeof window.top.restoreSession === 'function') {
                window.top.restoreSession();
            }
            if (hint.kind === 'patient_dashboard') {
                // Mirrors the OpenEMR top-bar patient-name link (Knockout binding
                // `click: refreshPatient` → `loadCurrentPatient()`). Activates the
                // "pat" tab if open, otherwise navigates and activates it.
                navigateDemographicsInChrome();
                return;
            }

            if (hint.kind === 'encounter') {
                var rawEnc = hint.params && hint.params.encounter_id;
                var encId =
                    typeof rawEnc === 'number'
                        ? rawEnc
                        : typeof rawEnc === 'string'
                            ? parseInt(rawEnc, 10)
                            : NaN;
                if (!(encId > 0)) {
                    return;
                }
                navigateEncounterInChrome(encId);
                return;
            }

            if (hint.kind === 'visit_history') {
                // Mirrors the OpenEMR top-patient-panel clock icon
                // (`clickEncounterList` → `encounterList()` → loads
                // `/interface/patient_file/history/encounters.php` in the
                // "enc" tab). Prefer the host's own helper so any future
                // tab-routing changes there carry into the copilot too.
                navigateVisitHistoryInChrome();
                return;
            }

            if (hint.kind === 'chart_section') {
                navigateChartSectionFromHint(hint.params);
                return;
            }

            if (frame.contentWindow) {
                frame.contentWindow.postMessage({ type: 'NAV_LIMITED' }, window.location.origin);
            }
            navigateDemographicsInChrome();
        });

        function ensurePanelLoaded() {
            if (panelLoaded || !frame || panelSrc === '') {
                return;
            }
            panelLoaded = true;
            frame.setAttribute('src', panelSrc);
        }

        function setCollapsed(collapsed) {
            rail.classList.toggle('agentforge-rail--collapsed', collapsed);
            splitter.classList.toggle('agentforge-rail-splitter--hidden', collapsed);
            toggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
            safeSessionSet(STORAGE_KEY_COLLAPSED, collapsed ? '1' : '0');
            if (!collapsed) {
                ensurePanelLoaded();
            }
        }

        toggle.addEventListener('click', function () {
            var nowCollapsed = !rail.classList.contains('agentforge-rail--collapsed');
            setCollapsed(nowCollapsed);
        });

        // Splitter: pointer-event drag clamped against MIN/MAX width and a min frame width.
        (function wireSplitter() {
            var dragging = false;
            var pointerId = null;

            function onPointerMove(ev) {
                if (!dragging) {
                    return;
                }
                var mainFrames = document.getElementById('mainFrames_div');
                if (!mainFrames) {
                    return;
                }
                var rect = mainFrames.getBoundingClientRect();
                // For LTR, column is on the right edge; width = (rect.right - clientX). RTL mirrors.
                var isRtl = (document.documentElement.getAttribute('dir') || '').toLowerCase() === 'rtl' ||
                    getComputedStyle(document.documentElement).direction === 'rtl';
                var rawWidth = isRtl ? (ev.clientX - rect.left) : (rect.right - ev.clientX);
                var maxByFrames = Math.max(MIN_WIDTH, Math.min(MAX_WIDTH, rect.width - MIN_FRAMES_WIDTH));
                var clamped = Math.min(maxByFrames, Math.max(MIN_WIDTH, rawWidth));
                applyWidth(clamped);
            }

            function endDrag(ev) {
                if (!dragging) {
                    return;
                }
                dragging = false;
                splitter.classList.remove('agentforge-rail-splitter--dragging');
                document.body.classList.remove('agentforge-rail-dragging');
                if (pointerId !== null) {
                    try {
                        splitter.releasePointerCapture(pointerId);
                    } catch (ignored) {
                    }
                    pointerId = null;
                }
                var current = parseInt(getComputedStyle(rail).getPropertyValue('--agentforge-rail-width') || '', 10);
                if (isFinite(current) && current > 0) {
                    safeSessionSet(STORAGE_KEY_WIDTH, String(current));
                }
                window.removeEventListener('pointermove', onPointerMove);
                window.removeEventListener('pointerup', endDrag);
                window.removeEventListener('pointercancel', endDrag);
            }

            splitter.addEventListener('pointerdown', function (ev) {
                if (ev.button !== 0) {
                    return;
                }
                ev.preventDefault();
                dragging = true;
                pointerId = ev.pointerId;
                try {
                    splitter.setPointerCapture(pointerId);
                } catch (ignored) {
                }
                splitter.classList.add('agentforge-rail-splitter--dragging');
                document.body.classList.add('agentforge-rail-dragging');
                window.addEventListener('pointermove', onPointerMove);
                window.addEventListener('pointerup', endDrag);
                window.addEventListener('pointercancel', endDrag);
            });

            // Keyboard arrows for accessibility.
            splitter.addEventListener('keydown', function (ev) {
                var step = ev.shiftKey ? 32 : 8;
                var current = parseInt(getComputedStyle(rail).getPropertyValue('--agentforge-rail-width') || '', 10);
                if (!isFinite(current) || current <= 0) {
                    current = defaultWidth;
                }
                var next = null;
                if (ev.key === 'ArrowLeft') {
                    next = current + step;
                } else if (ev.key === 'ArrowRight') {
                    next = current - step;
                } else if (ev.key === 'Home') {
                    next = MAX_WIDTH;
                } else if (ev.key === 'End') {
                    next = MIN_WIDTH;
                }
                if (next === null) {
                    return;
                }
                ev.preventDefault();
                var w = applyWidth(next);
                safeSessionSet(STORAGE_KEY_WIDTH, String(w));
            });
        })();

        // Relocate rail + splitter to live as siblings of #framesDisplay inside #mainFrames_div.
        // EVENT_BODY_RENDER_POST renders us at end-of-body; knockout populates #framesDisplay async.
        function relocateIntoMainFrames() {
            var mainFrames = document.getElementById('mainFrames_div');
            var framesDisplay = document.getElementById('framesDisplay');
            if (!mainFrames || !framesDisplay) {
                return false;
            }
            if (rail.parentNode !== mainFrames || splitter.parentNode !== mainFrames) {
                mainFrames.appendChild(splitter);
                mainFrames.appendChild(rail);
            }
            return true;
        }

        function tryRelocateLoop() {
            if (relocateIntoMainFrames()) {
                return;
            }
            var attempts = 0;
            var timer = setInterval(function () {
                attempts++;
                if (relocateIntoMainFrames() || attempts > 40) {
                    clearInterval(timer);
                }
            }, 100);
            // Also watch for DOM mutations — knockout's foreach over tabsList may not be live yet.
            if (typeof MutationObserver === 'function') {
                var rootObs = document.body;
                if (rootObs) {
                    var obs = new MutationObserver(function () {
                        if (relocateIntoMainFrames()) {
                            obs.disconnect();
                            clearInterval(timer);
                        }
                    });
                    obs.observe(rootObs, { childList: true, subtree: true });
                }
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', tryRelocateLoop, { once: true });
        } else {
            tryRelocateLoop();
        }

        // Initial collapsed state — restore from sessionStorage; default to expanded.
        var storedCollapsed = safeSessionGet(STORAGE_KEY_COLLAPSED) === '1';
        setCollapsed(storedCollapsed);
        if (!storedCollapsed) {
            ensurePanelLoaded();
        }
    })();
</script>
