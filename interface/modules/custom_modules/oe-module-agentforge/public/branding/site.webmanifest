{
  "id": "clinical-copilot",
  "name": "Clinical Copilot",
  "short_name": "Copilot",
  "description": "An AI documentation assistant embedded in OpenEMR. Drafts encounter notes, queries patient charts, and accelerates clinical workflow at the point of care.",
